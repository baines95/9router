{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "open-sse": ["src/open-sse-shims.d.ts"],
      "open-sse/*": ["src/open-sse-shims.d.ts"],
      "@/*": ["src/open-sse-shims.d.ts"]
    },
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.js",
    "src/**/*.mjs",
    "src/**/*.cjs",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts"
  ]
}
